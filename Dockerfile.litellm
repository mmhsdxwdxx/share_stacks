# Builder stage - compile Python dependencies
FROM ghcr.io/berriai/litellm:v1.50.0 AS builder

# Install build dependencies
RUN apk add --no-cache \
    gcc \
    musl-dev \
    postgresql-dev \
    libffi-dev \
    cargo \
    rust

# (Optional) Add custom Python packages here
# RUN pip install --no-cache-dir your-custom-package

# Runtime stage - minimal final image
FROM ghcr.io/berriai/litellm:v1.50.0

# Copy compiled dependencies from builder
COPY --from=builder /usr/local/lib/python3.*/site-packages /usr/local/lib/python3.*/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Set working directory
WORKDIR /app

# Create non-root user (matches official image)
RUN addgroup -g 1000 litellm && \
    adduser -D -u 1000 -G litellm litellm

# Expose LiteLLM default port
EXPOSE 4000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:4000/health || exit 1

# Run as non-root user
USER litellm

# Default command (matches official image)
CMD ["litellm", "--run_gunicorn"]
