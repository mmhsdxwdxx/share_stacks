# EditorConfig for share_stacks project
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.sh]
end_of_line = lf
charset = utf-8

[*.ps1]
end_of_line = crlf
charset = utf-8

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{json,conf}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
